generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The User table
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String
  password  String
  createdAt DateTime @default(now())
  
  // A User can have many Posts 
  posts     Post[]   
}

// The Post table for Circular Economy items
model Post {
  id          Int      @id @default(autoincrement())
  title       String   // e.g., "Used Bicycle"
  description String?  // e.g., "Good condition, needs new tires" (The '?' makes it optional)
  imageUrl    String   // The link to the file in our uploads folder
  createdAt   DateTime @default(now())
  
  // This links the Post back to the specific User who uploaded it
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}