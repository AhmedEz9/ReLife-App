generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Käyttäjä (User) taulu
model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  username  String
  password  String
  projects  Project[] 
  createdAt DateTime  @default(now())
}

// Projekti (Post/Upload) taulu
model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String?  
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}